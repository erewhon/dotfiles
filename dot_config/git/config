[rerere]
	enabled = true

[filter "lfs"]
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f

[pull]
    ff = only

[diff]
    colorMoved = default

[core]
    pager = delta
    # autocrlf = input

[delta]
     syntax-theme = Dracula
     line-numbers = true
#    side-by-side = true

[interactive]
     diffFilter = delta --color-only

# Host-local drop-ins (silently ignored if missing). Later wins on conflict,
# so order is identity → work → host, with host taking final priority.
[include]
     path = ~/.config/git/config.d/00-identity
[include]
     path = ~/.config/git/config.d/10-work
[include]
     path = ~/.config/git/config.d/20-host

[init]
	defaultBranch = main
[alias]
	change-commits = "!f() { VAR=$1; OLD=$2; NEW=$3; shift 3; git filter-branch --env-filter \"if [[ \\\"$`echo $VAR`\\\" = '$OLD' ]]; then export $VAR='$NEW'; fi\" $@; }; f"
