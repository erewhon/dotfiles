# -*- Mode: sh -*-
#
# Interactive zsh init. Modules live in $ZDOTDIR/rc.d/ (shipped via chezmoi);
# host-/env-local drop-ins go in $ZDOTDIR/zshrc.d/ (unmanaged) and load last
# so they can override anything from rc.d/.
#

# macOS chokes on tmux-256color
if [[ "$(uname)" == "Darwin" && "$TERM" == "tmux-256color" ]]; then
    TERM="screen-256color"
fi

# Shipped modules
for _file in "$ZDOTDIR"/rc.d/*.zsh(N); do
    source "$_file"
done

# Host-/env-local drop-ins (last wins)
for _file in "$ZDOTDIR"/zshrc.d/*.zsh(N); do
    source "$_file"
done

unset _file
