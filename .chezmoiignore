README.md

# Host classification: look up current host, fall back to defaults
{{ $host := .host_defaults }}
{{ if hasKey .hosts .chezmoi.hostname }}
{{   $host = index .hosts .chezmoi.hostname }}
{{ end }}

# Skip Brewfile on non-brew hosts
{{ if not (get $host "has_brew") }}
.config/Brewfile
{{ end }}

# Skip desktop-only configs on remote hosts
{{ if get $host "is_remote" }}
.config/ghostty
.config/iterm
.config/wezterm
{{ end }}

# Skip personal-only configs on non-personal hosts
{{ if not (get $host "is_personal") }}
.config/opencode
.local/share/crush
.claude/agents/content-researcher.md
.claude/agents/script-writer.md
.claude/agents/thumbnail-ideas.md
.claude/commands/blog-draft.md
.claude/commands/video-outline.md
.claude/commands/stream-prep.md
.claude/skills/content-creation
.claude/skills/story-explanation
.config/zellij/layouts/videopod.kdl
{{ end }}

# Skip macOS-only configs on Linux
{{ if eq .chezmoi.os "linux" }}
.config/iterm
{{ end }}
