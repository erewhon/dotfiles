#!/usr/bin/env bash
# nvim-reset — clean up Neovim caches, state, and orphaned plugins.
set -euo pipefail

echo "Removing Neovim cache and state..."
rm -rf ~/.cache/nvim ~/.local/state/nvim ~/.config/nvim/lazy-lock.json

# Remove legacy plugins.lua (pre-LazyVim config that conflicts with blink.cmp)
legacy="$HOME/.config/nvim/lua/plugins.lua"
if [[ -f "$legacy" ]]; then
    echo "Removing legacy plugin spec: $legacy"
    rm -f "$legacy"
fi

# Remove known orphaned plugins (leftover from LazyVim transitions)
orphans=(
    cmp-nvim-lsp    # nvim-cmp replaced by blink.cmp
    nvim-cmp        # replaced by blink.cmp
)

for plugin in "${orphans[@]}"; do
    dir="$HOME/.local/share/nvim/lazy/$plugin"
    if [[ -d "$dir" ]]; then
        echo "Removing orphaned plugin: $plugin"
        rm -rf "$dir"
    fi
done

echo "Done. Restart Neovim to rebuild."
