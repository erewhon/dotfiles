#!/usr/bin/env bash
# nvim-reset — clean up Neovim caches, state, and orphaned plugins.
set -euo pipefail

echo "Removing Neovim cache, state, and all plugins..."
rm -rf ~/.cache/nvim ~/.local/state/nvim ~/.local/share/nvim ~/.config/nvim/lazy-lock.json

# Remove legacy plugins.lua (pre-LazyVim config that conflicts with blink.cmp)
legacy="$HOME/.config/nvim/lua/plugins.lua"
if [[ -f "$legacy" ]]; then
    echo "Removing legacy plugin spec: $legacy"
    rm -f "$legacy"
fi

echo "Done. Restart Neovim to reinstall all plugins."
