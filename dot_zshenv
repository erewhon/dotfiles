# -*- Mode: sh -*-
#
# zsh startup for interactive and non-interactive shells
#

#
# Turn off macOS zsh session management
#
export SHELL_SESSIONS_DISABLE=1

#
# Set XDG-related variables
#
export XDG_CONFIG_HOME=${XDG_CONFIG_HOME:-$HOME/.config}
export XDG_CACHE_HOME=${XDG_CACHE_HOME:-$HOME/.cache}
export XDG_DATA_HOME=${XDG_DATA_HOME:-$HOME/.local/share}
export XDG_STATE_HOME=${XDG_STATE_HOME:-$HOME/.local/state}

export ZDOTDIR=${XDG_CONFIG_HOME}/zsh

# Homebrew / Linuxbrew
if [[ -d /opt/homebrew ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
elif [[ -d /home/linuxbrew/.linuxbrew ]]; then
    eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi

# Core paths (deduplicated by typeset -U)
typeset -U path
path=(
    ~/bin
    ~/.local/bin
    ~/.cargo/bin
    ~/.config/doom-emacs/bin
    ~/.krew/bin
    ~/.rd/bin
    /usr/local/bin
    /usr/local/sbin
    /snap/bin
    $path
)

# Go
if command -v go &>/dev/null; then
    export GOPATH=$(go env GOPATH)
    path=($(go env GOPATH)/bin $path)
fi

# Bun
if [[ -d "$HOME/.bun" ]]; then
    export BUN_INSTALL="$HOME/.bun"
    path=($BUN_INSTALL/bin $path)
fi
export HOARDFS_REPO=/data/hoardfs
